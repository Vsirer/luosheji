# ==========================================
# 逻设计 v1.0 环境变量配置文件
# ==========================================

# --- 核心配置 ---

# JWT 密钥 (用于用户登录验证，建议设置一个复杂的长字符串)
JWT_SECRET=your_jwt_secret_key_here

# 运行环境 (development 或 production)
NODE_ENV=development

# --- 数据库配置 (MySQL) ---
# 数据库主机地址 (如: rm-xxx.mysql.rds.aliyuncs.com 或 localhost)
DB_HOST=
# 数据库端口 (默认 3306)
DB_PORT=3306
# 数据库用户名
DB_USER=
# 数据库密码
DB_PASSWORD=
# 数据库名称
DB_NAME=

# --- 阿里云 OSS 配置 (可选，未配置则使用本地存储) ---
# OSS 区域 (如: oss-cn-hangzhou)
OSS_REGION=
# 阿里云 AccessKey ID
OSS_ACCESS_KEY_ID=
# 阿里云 AccessKey Secret
OSS_ACCESS_KEY_SECRET=
# OSS Bucket 名称
OSS_BUCKET=
