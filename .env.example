# ==========================================
# XIAOLUO AI OS 环境变量配置文件
# ==========================================

# --- 核心配置 ---
# 默认管理员用户名和密码 (可选配置，系统初次启动或账号不存在时会自动创建此管理员账号)
# DEFAULT_ADMIN_USERNAME=admin
# DEFAULT_ADMIN_PASSWORD=admin

# 运行环境 (development 或 production)
NODE_ENV=production

# --- 数据库配置 (MySQL) ---
# 数据库主机地址 (如: rm-xxx.mysql.rds.aliyuncs.com 或 localhost)
DB_HOST=
# 数据库端口 (默认 3306)
DB_PORT=3306
# 数据库用户名
DB_USER=
# 数据库密码
DB_PASSWORD=
# 数据库名称
DB_NAME=

# --- 阿里云 OSS 配置 (可选，未配置则使用本地存储) ---
# OSS 区域 (如: oss-cn-hangzhou)
OSS_REGION=oss-cn-hangzhou
# 阿里云 AccessKey ID
OSS_ACCESS_KEY_ID=
# 阿里云 AccessKey Secret
OSS_ACCESS_KEY_SECRET=
# OSS Bucket 名称
OSS_BUCKET=
# OSS 自定义域名或全局端点 (可选，如: oss.aliyuncs.com)
OSS_ENDPOINT=oss.aliyuncs.com